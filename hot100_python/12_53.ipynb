   "source": [
    "class Solution:\n",
    "    def maxSubArray(self, nums: List[int]) -> int:\n",
    "     \n",
    "\n",
    "        max_sum = nums[0]\n",
    "        ans = nums[0]\n",
    "        for num in nums[1:]:\n",
    "            \n",
    "            max_sum = max(max_sum+num,num)\n",
    "            ans = max(max_sum,ans)\n",
    "            \n",
    "\n",
    "        return ans"
   ]
  },
